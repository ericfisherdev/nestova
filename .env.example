# Nestova configuration — copy to .env for local development (.env is gitignored).
# Real environment variables always override values in .env.
# Every variable below is read by internal/platform/config.

# Deployment environment: dev | test | prod
APP_ENV=dev

# HTTP listen port (a leading colon is tolerated, e.g. ":8080").
PORT=8080

# Optional app-terminated TLS (NES-54). Set BOTH to have the server listen with
# TLS itself (ListenAndServeTLS); leave both unset to serve plain HTTP behind a
# reverse proxy (the default). See README "App-terminated TLS".
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem

# Postgres connection string. The default matches the docker-compose service.
DATABASE_URL=postgres://nestova:nestova@localhost:5432/nestova?sslmode=disable

# Connection pool cap. 0 lets the pool choose a sensible default.
DB_MAX_CONNS=0

# Bounds the initial Postgres connectivity check at startup (Go duration).
DB_CONNECT_TIMEOUT=5s

# --- Supabase (optional) -----------------------------------------------------
# The defaults above run against the local docker-compose Postgres. To use
# Supabase instead, set DB_PROVIDER=supabase and replace DATABASE_URL with a
# Supabase connection string (see README "Using Supabase"). Supabase is Postgres,
# so no schema/query changes are needed — only connectivity.
#
# DB_PROVIDER=supabase
# A long-running server should prefer the session pooler (or direct connection),
# port 5432. For the transaction pooler use port 6543 and DB_POOL_MODE=transaction.
# DB_POOL_MODE=session
# Supabase requires TLS; keep sslmode=require (sslmode=disable is rejected).
# DATABASE_URL=postgres://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require
# Run migrations against the direct/session connection (port 5432): DDL and goose
# bookkeeping need a session connection.
# MIGRATE_DATABASE_URL=postgres://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require
# Optional CA bundle for full certificate verification (enables sslmode=verify-full).
# DB_SSL_ROOT_CERT=/path/to/supabase-ca.crt
# Modest pool cap behind the shared pooler (defaults to 10 for Supabase when unset).
# DB_MAX_CONNS=10
# -----------------------------------------------------------------------------

# Signs session cookies. Must be at least 32 bytes. MUST be overridden in prod
# (the built-in dev default is rejected when APP_ENV=prod).
SESSION_SECRET=dev-only-insecure-session-secret-change-me

# Maximum session duration (Go duration).
SESSION_LIFETIME=12h

# Google OAuth credentials for Google Calendar sync. Required only in prod.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=

# Photo storage (rotating album). MEDIA_ROOT is where uploaded photo bytes are
# written; it has a safe default in every environment. MEDIA_MAX_UPLOAD_BYTES
# caps a single upload (default 10 MiB).
MEDIA_ROOT=./.localdata/media
MEDIA_MAX_UPLOAD_BYTES=10485760
